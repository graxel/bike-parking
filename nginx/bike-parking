# --- Internal-only endpoints (restrict to localhost / VPN) -------

# Health check (internal)
location /bike-parking/health/ {
    # Restrict access: only local and private networks
    allow 127.0.0.1;
    allow ::1;
    allow 192.168.0.0/16;
    allow 10.0.0.0/8;
    deny all;

    proxy_pass http://127.0.0.1:40500/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# Airflow webserver (internal)
location /bike-parking/airflow/ {
    # Restrict access: only local and private networks
    allow 127.0.0.1;
    allow ::1;
    allow 192.168.0.0/16;
    allow 10.0.0.0/8;
    deny all;

    proxy_pass http://127.0.0.1:40510/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Prefix /bike-parking/airflow;

    # Airflow UI uses WebSocket for log tailing
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_read_timeout 86400;
}
