# Bike Parking: Citi Bike dock availability tracker
# Ports:
#   40500 - Health/status (internal only)
#   40501 - History API (FastAPI)
#   40502 - Forecast API
#   40503 - Panic API
#   40510 - Airflow webserver (internal only)
#
# /bike-parking is replaced at deploy time:
#   prod → /bike-parking
#   qa   → /bike-parking/beta


# --- Public endpoints -------------------------------------------

# History API (current availability + history)
location /bike-parking/history/ {
    proxy_pass http://127.0.0.1:40501/history;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Prefix /bike-parking/history;

    proxy_hide_header 'Access-Control-Allow-Origin';

    add_header 'Access-Control-Allow-Origin' 'https://kevingrazel.com' always;
    add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
    add_header 'Access-Control-Allow-Headers' 'Content-Type, Authorization' always;

    if ($request_method = 'OPTIONS') {
        add_header 'Access-Control-Allow-Origin' 'https://kevingrazel.com' always;
        return 204;
    }
}

