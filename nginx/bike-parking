# Bike Parking: Citi Bike dock availability tracker
# Ports:
#   40500 - Health/status (internal only)
#   40501 - History/Current/Forecast API (FastAPI)
#   40510 - Airflow webserver (internal only)


location /bike-parking/ {
    proxy_pass http://127.0.0.1:40501/;
    proxy_hide_header Access-Control-Allow-Origin;
}

# Health check (internal)
location /bike-parking/health/ {
    # Restrict access: only local and private networks
    allow 127.0.0.1;
    allow ::1;
    allow 192.168.0.0/16;
    deny all;

    proxy_pass http://127.0.0.1:40500/;
}

# Airflow webserver (internal)
location /bike-parking/airflow/ {
    # Restrict access: only local and private networks
    allow 127.0.0.1;
    allow ::1;
    allow 192.168.0.0/16;
    deny all;

    proxy_pass http://127.0.0.1:40510/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Prefix /bike-parking/airflow;

    # Airflow UI uses WebSocket for log tailing
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_read_timeout 86400;
}

# --- Development Proxies (for LAN/Mobile testing) ----------------

# QA Data Proxy (Bypasses CORS for local dev)
location /bike-parking/qa-proxy/ {
    proxy_pass https://data.kevingrazel.com:8443/bike-parking/;
    proxy_ssl_server_name on;
    proxy_set_header Host data.kevingrazel.com;
    
    # Simple CORS for local dev
    add_header 'Access-Control-Allow-Origin' '*' always;
}

# Prod Data Proxy (Bypasses CORS for local dev)
location /bike-parking/prod-proxy/ {
    proxy_pass https://data.kevingrazel.com/bike-parking/;
    proxy_ssl_server_name on;
    proxy_set_header Host data.kevingrazel.com;

    # Simple CORS for local dev
    add_header 'Access-Control-Allow-Origin' '*' always;
}
